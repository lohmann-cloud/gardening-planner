# Copy this file to .env and fill in your values

# Local (Docker): postgresql://garden:garden_secret@localhost:5432/garden_planner
# Neon (prod):    postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=""

POSTGRES_USER=garden
POSTGRES_PASSWORD=garden_secret
POSTGRES_DB=garden_planner

PGADMIN_EMAIL=admin@garden.local
PGADMIN_PASSWORD=admin
