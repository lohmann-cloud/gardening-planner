# Copy this file to .env and fill in your values

# Local (Docker): postgresql://garden:garden_secret@localhost:5432/garden_planner
# Neon (prod):    postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=""

POSTGRES_USER=garden
POSTGRES_PASSWORD=garden_secret
POSTGRES_DB=garden_planner

PGADMIN_EMAIL=admin@garden.local
PGADMIN_PASSWORD=admin

# Google OAuth 2.0 Web client ID, used to verify Google ID tokens sent
# from the frontend. Create one at https://console.cloud.google.com/
# under APIs & Services > Credentials. Leave blank to disable audience
# verification (development only).
GOOGLE_OAUTH_CLIENT_ID=

